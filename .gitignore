# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Test and emulator output. Keep fixtures under tests/**/fixtures tracked.
*.log
backups/
backup/
.backup/
tmp/
.tmp/
temp/
.temp/
coverage/
*.sqlite
*.sqlite3
*.db
!tests/**/fixtures/**/*.sqlite
!tests/**/fixtures/**/*.sqlite3
!tests/**/fixtures/**/*.db

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files (commit the documented template only)
.env
.env.local
!.env.example

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# local bundled model
assets/models/local-llm.gguf
