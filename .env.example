EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Stable public salt/domain separator for anonymous sync diagnostics.
# Changing it breaks cross-release anonymous-user correlation.
EXPO_PUBLIC_SYNC_LOG_SALT=wememo-sync-observability-v1

# Optional local/EAS file-secret paths used by React Native Firebase config.
GOOGLE_SERVICES_PLIST=./ios/Temis/GoogleService-Info.plist
GOOGLE_SERVICES_JSON=
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=
EXPO_PUBLIC_REVENUECAT_CLOUD_SYNC_ENTITLEMENT_ID=cloud_sync
EXPO_PUBLIC_REVENUECAT_CLOUD_SYNC_OFFERING_ID=cloud_sync_default
EXPO_PUBLIC_REVENUECAT_CLOUD_SYNC_PACKAGE_ID=$rc_monthly
